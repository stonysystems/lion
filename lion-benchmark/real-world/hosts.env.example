# Cross-machine topology for the real-world benchmarks. Copy to `hosts.env`
# (which is gitignored) and edit. With no hosts.env, every run.sh runs LOCALLY
# (server + client on this host) — a single-machine smoke.
#
#   cp hosts.env.example hosts.env && $EDITOR hosts.env
#
# The paper's setup: server on the anchor machine (an AMD EPYC 7702P box,
# "zoo-002" in the reference batches), load generator on a second host
# ("zoo-004"); Axum additionally runs its localhost deployment on the server.
# Credentials are NOT stored here — set SSH_PASS locally in your gitignored
# hosts.env copy.

# `:=` form so an environment variable overrides the file (CLIENT_HOST=127.0.0.1 ./run.sh).
# Where the server (proxy/broker/file-server) runs. 127.0.0.1 = local.
: "${SERVER_HOST:=127.0.0.1}"
# Where the load generator (wrk / mqtt-benchmark) runs. 127.0.0.1 = local.
: "${CLIENT_HOST:=127.0.0.1}"
# Hostname label written into PROVENANCE.txt instead of the raw address:
: "${CLIENT_NAME:=}"

# Needed only when CLIENT_HOST (or remote launch) is not local:
: "${SSH_USER:=}"
: "${SSH_PASS:=}"
# Path to this repo on the server host (for lib/remote_launch.sh):
: "${REMOTE_REPO:=}"

# Example two-host config:
# SERVER_HOST=10.0.0.2       # server / anchor machine
# CLIENT_HOST=10.0.0.4       # load generator
# CLIENT_NAME=client-host    # label recorded in PROVENANCE.txt
# SSH_USER=you
# REMOTE_REPO=/home/you/lion
